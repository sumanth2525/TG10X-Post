# Copy to .env (never commit .env)
TG10X_EMAIL=your@email.com
TG10X_PASSWORD=your_password
TG10X_BASE_URL=https://tg10x.com

# Optional: custom post body (otherwise a default “we’re hiring” message is used)
# TG10X_POST_TEXT=We're hiring for ...

# Skip profile steps and only login + post (use when profile is already complete)
# POST_ONLY=1

# Skip posting after profile
# SKIP_POST=1

# OPENAI_API_KEY=  (optional — see agent-profile.mjs)

# Browser: by default the script opens a VISIBLE window (better for login).
# Set HEADLESS=1 only if you need headless (login may fail on some sites).
# USE_CHROME=1 uses installed Google Chrome instead of bundled Chromium.
